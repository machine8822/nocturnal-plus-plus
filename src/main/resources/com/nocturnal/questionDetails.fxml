                  </Label>
               </children>
            </HBox>
            <VBox prefHeight="62.0" prefWidth="720.0" spacing="4.0" style="-fx-background-color: rgba(10,10,24,0.85); -fx-background-radius: 5; -fx-border-color: #9a9ab6; -fx-border-radius: 5; -fx-border-width: 1;">
               <children>
                  <Label text="Desciption" textFill="#8d8da9">
                     <font>
                        <Font size="8.0" />
