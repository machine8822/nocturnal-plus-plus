                  </Label>
                  <TextArea fx:id="description" editable="false" prefHeight="40.0" prefWidth="690.0" style="-fx-background-color: transparent; -fx-control-inner-background: #0C0C1C; -fx-text-fill: #e8e8f2; -fx-border-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" wrapText="true" />
               </children>
               <padding>
