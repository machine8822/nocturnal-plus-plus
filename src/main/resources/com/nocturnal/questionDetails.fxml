               </padding>
            </VBox>
            <VBox prefHeight="48.0" prefWidth="720.0" spacing="4.0" style="-fx-background-color: rgba(10,10,24,0.85); -fx-background-radius: 5; -fx-border-color: #9a9ab6; -fx-border-radius: 5; -fx-border-width: 1;">
               <children>
                  <Label text="Constraints" textFill="#8d8da9">
                     <font>
                        <Font size="8.0" />
                     </font>
                  </Label>
                  <TextArea fx:id="constraints" editable="false" prefHeight="25.0" prefWidth="690.0" style="-fx-background-color: transparent; -fx-control-inner-background: #0C0C1C; -fx-text-fill: #e8e8f2; -fx-border-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" wrapText="true" />
               </children>
               <padding>
                  <Insets bottom="6.0" left="8.0" right="8.0" top="5.0" />
               </padding>
            </VBox>
            <VBox prefHeight="36.0" prefWidth="720.0" spacing="4.0" style="-fx-background-color: rgba(10,10,24,0.85); -fx-background-radius: 5; -fx-border-color: #9a9ab6; -fx-border-radius: 5; -fx-border-width: 1;">
               <children>
                  <Label text="Example" textFill="#8d8da9">
                     <font>
                        <Font size="8.0" />
                     </font>
                  </Label>
                  <TextArea fx:id="examples" editable="false" prefHeight="16.0" prefWidth="690.0" style="-fx-background-color: transparent; -fx-control-inner-background: #0C0C1C; -fx-text-fill: #e8e8f2; -fx-border-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" wrapText="true" />
               </children>
               <padding>
                  <Insets bottom="5.0" left="8.0" right="8.0" top="4.0" />
               </padding>
            </VBox>
            <Region prefHeight="14.0" />
            <Button fx:id="answer" mnemonicParsing="false" onAction="#showAnswerPopup" prefHeight="31.0" prefWidth="720.0" style="-fx-background-color: #1B1B3A; -fx-background-radius: 6; -fx-border-color: #30305a; -fx-border-radius: 6;" text="Show Answer" textFill="#ffbd2e">
               <font>
                  <Font name="System Bold" size="11.0" />
               </font>
            </Button>
            <HBox prefHeight="28.0" prefWidth="720.0" spacing="10.0" />
         </children>
      </VBox>
   </children>
</AnchorPane>
