   minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25"
   xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.QuestionLibrary">
   <children>
      <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Question Library" />
      <VBox fx:id="questionLibrary" prefHeight="200.0" prefWidth="100.0" />
