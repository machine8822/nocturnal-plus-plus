<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="480.0" prefWidth="640.0" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.QuestionLibrary">
   <children>
      <Label styleClass="title" text="Question Library" />
      <ListView fx:id="questionList" prefHeight="200.0" prefWidth="200.0" />
      <Button fx:id="goToDashboard" mnemonicParsing="false" onAction="#goToDashboard" text="Back to Dashboard" />
      <Button fx:id="logout" mnemonicParsing="false" onAction="#logout" text="Sign Out" />
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <stylesheets>
      <URL value="@styles.css" />
   </stylesheets>
</VBox>
